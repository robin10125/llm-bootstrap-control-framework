        },
        {
          "actuators": [
            "base_y"
          ],
          "expr": "clip(-obj_rel_y/0.05,-1,1)"
        },
        {
          "actuators": [
            "base_z"
          ],
          "expr": "0.5"
        },
        {
          "actuators": [
            "wrist"
          ],
          "expr": "clip(-obj_rel_y/0.05,-0.1,0.1)"
