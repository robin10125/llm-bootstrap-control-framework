        }
      ]
    },
    {
      "name": "lift",
      "gate": "gripped*(lift<0.06)",
      "channels": [
        {
          "actuators": [
            "base_z"
          ],
          "expr": "-0.55"
        },
        {
          "actuators": [
            "thumb",
            "index",
            "middle",
            "ring",
            "little"
          ],
          "expr": "0.15"
        },
        {
          "actuators": [
            "wrist"
          ],
          "expr": "0.05"
        }
      ]
    },
    {
      "name": "hold",
      "gate": "gripped*(lift>=0.06)",
      "channels": [
        {
          "actuators": [
            "thumb",
            "index",
            "middle",
            "ring",
            "little"
          ],
          "expr": "0.05"
        }
      ]
