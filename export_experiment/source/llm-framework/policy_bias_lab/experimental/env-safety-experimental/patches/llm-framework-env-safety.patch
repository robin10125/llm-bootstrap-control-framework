+def _compile_constraint(env: Any, c: dict, signal_names: set[str],
+                        obs_idx: dict[str, int]) -> tuple[str, Callable, str, list[tuple[jp.ndarray, Callable]]]:
+    """Compile one stage-local constraint.
+
+    A constraint is an author-defined priority layer over the active stage's nominal channels:
+    {"name", "active"|"violation": "<expr>", "mode": "replace"|"add", "channels": [...]}
+
+    The activation is clipped to [0, 1]. In replace mode, the constraint's channels replace the
+    nominal stage command on only the actuators they name; other actuators keep the nominal command.
+    This gives the author a task-agnostic way to project a desired motion onto an admissible
+    boundary plus buffer, without turning the whole stage off.
+    """
+    name = str(c.get("name") or "constraint")
+    src = c.get("active", c.get("violation", "0"))
+    ev_raw = compile_expr(str(src), signal_names)
+    mode = str(c.get("mode", "replace")).lower()
+    if mode not in {"replace", "add"}:
+        raise ValueError(f"constraint {name!r} mode must be 'replace' or 'add', got {mode!r}")
+    chans = [_compile_channel(env, ch, signal_names, obs_idx) for ch in (c.get("channels") or [])]
+
+    def active(sig, _ev=ev_raw):
+        return jp.clip(jp.asarray(_ev(sig), jp.float32), 0.0, 1.0)
+
+    return name, active, mode, chans
+
+
+def _apply_constraints(stage_out: jp.ndarray, constraints: list[tuple[str, Callable, str, list[tuple[jp.ndarray, Callable]]]],
+                       obs: jp.ndarray, sig: dict[str, jp.ndarray]) -> jp.ndarray:
+    out = stage_out
+    for _name, active_ev, mode, chans in constraints:
+        a = active_ev(sig)
+        if not chans:
+            continue
+        c_out = jp.zeros_like(out)
+        c_mask = jp.zeros_like(out)
+        for idx, ev in chans:
+            c_out = c_out.at[idx].add(jp.clip(ev(obs, sig), -1.0, 1.0))
+            c_mask = c_mask.at[idx].set(1.0)
+        if mode == "add":
+            out = out + a * c_out
+        else:
+            out = out * (1.0 - a * c_mask) + c_out * (a * c_mask)
+    return jp.clip(out, -1.0, 1.0)
+
