+def _ev_contact_forces(rep: dict, diag: dict, k: int) -> str | None:
+    cf = rep.get("contact_forces")
+    if not isinstance(cf, dict):
+        return None
+
+    def row(kind: str) -> dict | None:
+        block = cf.get(kind) or {}
+        rows = block.get("per_stage") or []
+        return rows[k] if k < len(rows) and isinstance(rows[k], dict) else None
+
+    def summarize(r: dict | None) -> str | None:
+        if not r:
+            return None
+        vals = []
+        for reg, v in r.items():
+            if reg in ("stage", "max_any_region") or not isinstance(v, dict):
+                continue
+            mx = v.get("max")
+            mean = v.get("mean")
+            if mx is not None and (mx > 0.0 or (mean is not None and mean > 0.0)):
+                vals.append((reg, mean, mx))
+        if not vals:
+            return "none"
+        vals.sort(key=lambda x: (x[2] if x[2] is not None else 0.0), reverse=True)
+        return ", ".join(f"{reg} mean {mean} max {mx}" for reg, mean, mx in vals[:4])
+
+    obj = summarize(row("object_contact"))
+    env = summarize(row("environment_contact"))
+    if obj is None and env is None:
+        return None
+    return (f"CONTACT FORCES while stage {k} is active (N): object-contact by region: "
+            f"{obj or 'unreported'}; environment-contact by region: {env or 'unreported'}. "
+            "Use these as separate sensed quantities: object contact and environment contact are "
+            "not interchangeable.")
+
+
+def _ev_constraints(rep: dict, diag: dict, k: int) -> str | None:
+    rows = rep.get("constraints")
+    if not isinstance(rows, list) or k >= len(rows):
+        return None
+    stage_row = rows[k] if isinstance(rows[k], dict) else {}
+    constraints = stage_row.get("constraints") or []
+    if not constraints:
+        return None
+    parts = []
+    for c in constraints:
+        if not isinstance(c, dict):
+            continue
+        parts.append(
+            f"{c.get('name')}: mean {c.get('mean')}, max {c.get('max')}, "
+            f"active_frac {c.get('active_frac')}, while_stage_mean {c.get('while_stage_mean')}, "
+            f"while_stage_active_frac {c.get('while_stage_active_frac')}")
+    if not parts:
+        return None
+    return ("STAGE-LOCAL CONSTRAINT ACTIVATION for the focused stage: "
+            + "; ".join(parts)
+            + ". These are authored recovery/projection activations, not gate hand-offs; use them "
+              "to see whether local admissibility rules are inactive, overactive, or cancelling "
+              "progress while the stage is dominant.")
+
