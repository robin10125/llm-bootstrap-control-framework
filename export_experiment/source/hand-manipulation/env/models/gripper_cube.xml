<!-- A deliberately simple manipulation scene: a floating parallel-jaw gripper that can
     translate in x/y/z and open/close two fingers, plus a free cube resting on a table.
     This is the offline-first stepping stone (see README); the bridge's primitive and
     observation surface is authored against the NAMES below, so swapping in a dexterous
     hand from mujoco_menagerie later is a model-file change, not a harness change. -->
<mujoco model="gripper_cube">
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"/>

  <default>
    <joint damping="1" armature="0.01"/>
    <geom friction="1.0 0.05 0.001" solref="0.01 1" solimp="0.95 0.99 0.001"/>
    <position kp="80" ctrlrange="-1 1"/>
  </default>

  <worldbody>
    <light name="top" pos="0 0 1.2" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <!-- fixed camera for the step-through viewer; tracks the cube as it is lifted -->
    <camera name="closeup" pos="0.45 -0.45 0.40" mode="targetbody" target="cube"/>
    <!-- table surface at z=0 -->
    <geom name="table" type="plane" size="0.5 0.5 0.01" rgba="0.7 0.7 0.7 1"/>

    <!-- floating gripper: 3 slide DOFs for the palm + 2 finger DOFs -->
    <body name="palm" pos="0 0 0">
      <joint name="slide_x" type="slide" axis="1 0 0" range="-0.30 0.30"/>
      <joint name="slide_y" type="slide" axis="0 1 0" range="-0.30 0.30"/>
      <joint name="slide_z" type="slide" axis="0 0 1" range="0.06 0.45"/>
      <geom name="palm" type="box" size="0.04 0.06 0.02" rgba="0.2 0.4 0.8 1" mass="0.5"/>
      <site name="grasp_center" pos="0 0 -0.07" size="0.005" rgba="1 0 0 0.4"/>

      <!-- left finger: qpos high = open (sits at +y), qpos 0 = closed (y=0) -->
      <body name="left_finger" pos="0 0 -0.02">
        <joint name="left_finger" type="slide" axis="0 1 0" range="0 0.05"/>
        <geom name="left_finger" type="box" size="0.008 0.006 0.04" pos="0 0 -0.04"
              rgba="0.9 0.6 0.2 1" mass="0.05"/>
      </body>
      <!-- right finger: qpos high = open (sits at -y) -->
      <body name="right_finger" pos="0 0 -0.02">
        <joint name="right_finger" type="slide" axis="0 -1 0" range="0 0.05"/>
        <geom name="right_finger" type="box" size="0.008 0.006 0.04" pos="0 0 -0.04"
              rgba="0.9 0.6 0.2 1" mass="0.05"/>
      </body>
    </body>

    <!-- the object to manipulate: a free cube resting on the table -->
    <body name="cube" pos="0.0 0.0 0.02">
      <freejoint name="cube"/>
      <geom name="cube" type="box" size="0.02 0.02 0.02" rgba="0.8 0.2 0.2 1" mass="0.05"/>
    </body>
  </worldbody>

  <actuator>
    <position name="slide_x" joint="slide_x" ctrlrange="-0.30 0.30"/>
    <position name="slide_y" joint="slide_y" ctrlrange="-0.30 0.30"/>
    <position name="slide_z" joint="slide_z" ctrlrange="0.06 0.45" kp="200"/>
    <position name="left_finger" joint="left_finger" ctrlrange="0 0.05" kp="60"/>
    <position name="right_finger" joint="right_finger" ctrlrange="0 0.05" kp="60"/>
  </actuator>

  <keyframe>
    <!-- home: gripper up and open, cube centred on the table -->
    <key name="home"
         qpos="0 0 0.30 0.05 0.05  0 0 0.02 1 0 0 0"
         ctrl="0 0 0.30 0.05 0.05"/>
  </keyframe>
</mujoco>
