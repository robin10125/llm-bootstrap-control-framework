<mujoco model="parallel_jaw_gripper">
  <option impratio="10" cone="elliptic"/>

  <worldbody>
    <geom name="table" size="0.5 0.5 0.01" type="plane" rgba="0.7 0.7 0.7 1"/>
    <!-- Same flipped-base convention as the Shadow scene: positive slide_z lowers the palm. -->
    <body name="g_base" pos="0 0 0.30" quat="0 1 0 0" gravcomp="1">
      <inertial pos="0 0 0.02" mass="1.5" diaginertia="0.004 0.004 0.003"/>
      <joint name="slide_x" pos="0 0 0" axis="1 0 0" type="slide" range="-0.3 0.3" armature="0.5" damping="60" frictionloss="0"/>
      <joint name="slide_y" pos="0 0 0" axis="0 1 0" type="slide" range="-0.3 0.3" armature="0.5" damping="60" frictionloss="0"/>
      <joint name="slide_z" pos="0 0 0" axis="0 0 1" type="slide" range="-0.15 0.2" armature="0.5" damping="60" frictionloss="0"/>
      <geom name="g_mount" type="cylinder" size="0.02 0.02" pos="0 0 0.02" rgba="0.3 0.3 0.35 1"/>
      <body name="g_palm" pos="0 0 0.06" gravcomp="1">
        <inertial pos="0 0 0" mass="0.4" diaginertia="0.0004 0.0004 0.0004"/>
        <geom name="g_palm_geom" type="box" size="0.030 0.075 0.014" rgba="0.25 0.25 0.3 1"/>
        <site name="grasp_site" pos="0 0 0.075" group="4"/>
        <body name="g_left_finger" pos="0 0.012 0.014" gravcomp="1">
          <inertial pos="0 0 0.04" mass="0.08" diaginertia="6e-05 6e-05 1e-05"/>
          <joint name="g_left_joint" pos="0 0 0" axis="0 1 0" type="slide" range="0 0.06" damping="8" armature="0.05"/>
          <geom name="g_left_pad" type="box" size="0.015 0.005 0.045" pos="0 0 0.045"
                condim="4" friction="1.5 0.05 0.001" solref="0.005" solimp="0.5 0.99 0.0001" rgba="0.8 0.8 0.85 1"/>
        </body>
        <body name="g_right_finger" pos="0 -0.012 0.014" gravcomp="1">
          <inertial pos="0 0 0.04" mass="0.08" diaginertia="6e-05 6e-05 1e-05"/>
          <joint name="g_right_joint" pos="0 0 0" axis="0 -1 0" type="slide" range="0 0.06" damping="8" armature="0.05"/>
          <geom name="g_right_pad" type="box" size="0.015 0.005 0.045" pos="0 0 0.045"
                condim="4" friction="1.5 0.05 0.001" solref="0.005" solimp="0.5 0.99 0.0001" rgba="0.8 0.8 0.85 1"/>
        </body>
      </body>
    </body>
    <body name="object" pos="0 0 0.025">
      <joint type="free"/>
      <geom name="cube" size="0.025 0.025 0.025" type="box" condim="4" friction="1 0.05 0.001" mass="0.05" rgba="0.8 0.2 0.2 1"/>
    </body>
  </worldbody>

  <actuator>
    <general name="g_left" joint="g_left_joint" ctrllimited="true" ctrlrange="0 0.06" forcelimited="true" forcerange="-25 25" biastype="affine" gainprm="120" biasprm="0 -120"/>
    <general name="g_right" joint="g_right_joint" ctrllimited="true" ctrlrange="0 0.06" forcelimited="true" forcerange="-25 25" biastype="affine" gainprm="120" biasprm="0 -120"/>
    <general name="base_x" joint="slide_x" ctrllimited="true" ctrlrange="-0.3 0.3" forcelimited="true" forcerange="-50 50" biastype="affine" gainprm="500" biasprm="0 -500"/>
    <general name="base_y" joint="slide_y" ctrllimited="true" ctrlrange="-0.3 0.3" forcelimited="true" forcerange="-50 50" biastype="affine" gainprm="500" biasprm="0 -500"/>
    <general name="base_z" joint="slide_z" ctrllimited="true" ctrlrange="-0.15 0.2" forcelimited="true" forcerange="-50 50" biastype="affine" gainprm="1000" biasprm="0 -1000"/>
  </actuator>
</mujoco>
