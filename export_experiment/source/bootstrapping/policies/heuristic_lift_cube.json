{
  "name": "heuristic_lift_cube",
  "goal": "grasp the cube and lift it above 0.12m",
  "setup": {
    "cube_xy": [0.04, -0.02]
  },
  "steps": [
    {
      "primitive": "open_gripper",
      "params": {"width": 0.065},
      "duration_s": 0.25,
      "note": "make room for the cube"
    },
    {
      "primitive": "move_tool",
      "params": {"x": 0.04, "y": -0.02, "z": 0.16},
      "duration_s": 0.80,
      "note": "approach above the cube"
    },
    {
      "primitive": "move_tool",
      "params": {"x": 0.04, "y": -0.02, "z": 0.075},
      "duration_s": 0.65,
      "note": "descend to grasp height"
    },
    {
      "primitive": "close_gripper",
      "params": {"force": 0.85},
      "duration_s": 0.35,
      "assert": [
        {"metric": "grasped", "op": "==", "value": true}
      ]
    },
    {
      "primitive": "lift",
      "params": {"z": 0.18},
      "duration_s": 0.75,
      "assert": [
        {"metric": "cube.z", "op": ">=", "value": 0.12}
      ]
    }
  ],
  "success": [
    {"metric": "grasped", "op": "==", "value": true},
    {"metric": "cube.z", "op": ">=", "value": 0.12}
  ]
}
