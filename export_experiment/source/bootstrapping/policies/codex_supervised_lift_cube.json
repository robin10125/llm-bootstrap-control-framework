{
  "name": "codex_supervised_lift_cube",
  "goal": "Codex-refined Shadow Hand cube grasp and lift demonstration for imitation training",
  "setup": {
    "object_pos": [0.0, 0.0, 0.025]
  },
  "steps": [
    {
      "primitive": "hand_pose",
      "params": {"name": "open hand"},
      "duration_s": 0.25
    },
    {
      "primitive": "set_base",
      "params": {"x": -0.0466, "y": 0.0047, "z": 0.0587},
      "duration_s": 0.704,
      "note": "approach with the palm high enough to avoid early cube shove"
    },
    {
      "primitive": "set_base",
      "params": {"x": -0.031, "y": -0.0212, "z": 0.1036},
      "duration_s": 1.001,
      "note": "descend and bias the fingers laterally so the cube seats between multiple fingertips"
    },
    {
      "primitive": "hand_pose",
      "params": {"name": "pre grasp"},
      "duration_s": 0.381
    },
    {
      "primitive": "hand_pose",
      "params": {"name": "grasp hard"},
      "duration_s": 1.458,
      "assert": [
        {"metric": "contacts.hand_object_count", "op": ">=", "value": 2}
      ]
    },
    {
      "primitive": "wait",
      "params": {},
      "duration_s": 0.357,
      "note": "settle contacts before lifting"
    },
    {
      "primitive": "set_base",
      "params": {"x": -0.0329, "y": -0.0283, "z": -0.0226},
      "duration_s": 0.862,
      "note": "lift while preserving the lateral grasp bias"
    }
  ],
  "success": [
    {"metric": "lifted", "op": "==", "value": true},
    {"metric": "contacts.hand_object_count", "op": ">=", "value": 2}
  ]
}
