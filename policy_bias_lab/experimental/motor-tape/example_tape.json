{
  "mode": "motor_tape",
  "name": "hand_written_smoke_plan",
  "_note": "base targets use the PROBED calibration (motor_tape.probe_base_calibration): per +1 ctrl unit, base_x moves obj_rel_x by -1.0, base_y moves obj_rel_y by +1.0 (inverted axis), base_z moves obj_rel_z by +1.0. So zeroing obj_rel_x ADDS it to base_x's start ctrl, zeroing obj_rel_y SUBTRACTS, and an obj_rel_z target t needs delta = t - obj_rel_z.",
  "signals": {},
  "parameters": {
    "close_frac": {"init": 0.7, "range": [0.0, 1.0]},
    "hover_rel_z": {"init": -0.15, "range": [-0.2, -0.1]},
    "grasp_rel_z": {"init": -0.04, "range": [-0.08, -0.01]},
    "lift_rel_z": {"init": -0.3, "range": [-0.35, -0.2]}
  },
  "defaults": {"interp": "minjerk"},
  "keyframes": [
    {"t": 3.0, "label": "center the grasp point over the object at hover height",
     "targets": {
       "base_x": "ctrl_init_self + obj_rel_x",
       "base_y": "ctrl_init_self - obj_rel_y",
       "base_z": "ctrl_init_self + hover_rel_z - obj_rel_z"}},
    {"t": 6.0, "label": "descend to grasp depth",
     "targets": {"base_z": "ctrl_init_self + grasp_rel_z - obj_rel_z"}},
    {"t": 9.5, "label": "close fingers on object",
     "targets": {
       "thumb": "ctrl_init_self + close_frac * (ctrl_hi_self - ctrl_init_self)",
       "index": "ctrl_init_self + close_frac * (ctrl_hi_self - ctrl_init_self)",
       "middle": "ctrl_init_self + close_frac * (ctrl_hi_self - ctrl_init_self)",
       "ring": "ctrl_init_self + close_frac * (ctrl_hi_self - ctrl_init_self)",
       "little": "ctrl_init_self + close_frac * (ctrl_hi_self - ctrl_init_self)"
     }},
    {"t": 13.0, "label": "lift",
     "targets": {"base_z": "ctrl_init_self + lift_rel_z - obj_rel_z"}},
    {"t": 18.0, "label": "hold lifted",
     "targets": {"base_z": "ctrl_init_self + lift_rel_z - obj_rel_z"}}
  ]
}
